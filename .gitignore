# ──────────────────────────────────────────────────────────────────
# Wara-IA — .gitignore
# ──────────────────────────────────────────────────────────────────

# ── Environnements virtuels Python ────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Cache Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]           # .pyc, .pyo, .pyd
*.pdb

# ── Distribution / packaging ──────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Cache Hugging Face (modèles téléchargés) ──────────────────────
.cache/
huggingface_cache/

# ── Variables d'environnement et secrets ──────────────────────────
.env
*.env
*.secret

# ── Éditeurs et IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Système d'exploitation ────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Journaux ──────────────────────────────────────────────────────
*.log
logs/
